# Mini CPO Platform - environment variables
# Zkopíruj tento soubor jako `.env` a doplň reálné hodnoty.

# === MQTT Broker ===
MQTT_HOST=mosquitto
MQTT_PORT=1883
# MQTT_USERNAME=
# MQTT_PASSWORD=

# === Backend ===
BACKEND_PORT=3000
# Cena za 1 kWh (např. 5.50 CZK / kWh)
PRICE_PER_KWH=5.50
# Heartbeat timeout v sekundách - kdy stanice je považována za offline
HEARTBEAT_TIMEOUT_SEC=90

# === Database ===
# Pokud používáš Postgres / MySQL, vyplň. Pokud SQLite / Mongo, uprav dle potřeby.
DB_HOST=db
DB_PORT=5432
DB_NAME=cpo
DB_USER=cpo
DB_PASSWORD=cpo

# === Frontend ===
FRONTEND_PORT=8080
# URL backend API z prohlížeče (pokud běží FE jako SPA)
API_URL=http://localhost:3000

# === Simulátor stanice (override per service v docker-compose.yml) ===
# STATION_ID=ST-001
# MAX_POWER_KW=22.0
# FAULT_PROBABILITY=0.05

      "Edit(**)",
      "Write(**)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(tree:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(pwd)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(test:*)",
      "Bash(git:*)",
      "Bash(docker compose:*)",
      "Bash(docker ps)",
      "Bash(docker ps:*)",
      "Bash(docker logs:*)",
      "Bash(docker images)",
      "Bash(docker images:*)",
      "Bash(docker inspect:*)",
      "Bash(docker exec:*)",
      "Bash(docker network:*)",
      "Bash(docker volume:*)",
      "Bash(mosquitto_sub:*)",
      "Bash(mosquitto_pub:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(ruff:*)",
      "Bash(uvicorn:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(psql:*)",
      "WebFetch(domain:docs.python.org)",
      "WebFetch(domain:fastapi.tiangolo.com)",
      "WebFetch(domain:docs.sqlalchemy.org)",
      "WebFetch(domain:sbtinstruments.github.io)",
      "WebFetch(domain:mosquitto.org)",
      "WebFetch(domain:react.dev)",
      "WebFetch(domain:vite.dev)",
      "WebFetch(domain:tailwindcss.com)",
      "WebFetch(domain:recharts.org)",
      "WebFetch(domain:typescriptlang.org)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:tabler.io)"

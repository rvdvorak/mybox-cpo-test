{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "plan",
    "allow": [
      "Read(/**)",
      "Edit(/**)",
      "Write(/**)",

      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(tree:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(pwd)",
      "Bash(test:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",

      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",

      "Bash(git:*)",

      "Bash(docker compose:*)",
      "Bash(docker ps)",
      "Bash(docker ps:*)",
      "Bash(docker logs:*)",
      "Bash(docker images)",
      "Bash(docker images:*)",
      "Bash(docker inspect:*)",
      "Bash(docker exec:*)",
      "Bash(docker network:*)",
      "Bash(docker volume:*)",
      "Bash(docker build:*)",
      "Bash(docker stop:*)",
      "Bash(docker start:*)",
      "Bash(docker restart:*)",
      "Bash(docker rm:*)",
      "Bash(docker kill:*)",

      "Bash(mosquitto_sub:*)",
      "Bash(mosquitto_pub:*)",

      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(ruff:*)",
      "Bash(uvicorn:*)",

      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",

      "Bash(psql:*)",
      "Bash(pg_isready:*)",

      "Bash(curl:*)",

      "Bash(bash scripts/verify/:*)",

      "WebFetch(domain:docs.python.org)",
      "WebFetch(domain:fastapi.tiangolo.com)",
      "WebFetch(domain:docs.sqlalchemy.org)",
      "WebFetch(domain:aiomqtt.felixboehm.dev)",
      "WebFetch(domain:mosquitto.org)",
      "WebFetch(domain:react.dev)",
      "WebFetch(domain:vite.dev)",
      "WebFetch(domain:tailwindcss.com)",
      "WebFetch(domain:recharts.org)",
      "WebFetch(domain:typescriptlang.org)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:tabler.io)",
      "WebFetch(domain:docs.docker.com)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:nodejs.org)"
    ],
    "deny": [
      "Read(~/.claude/.credentials.json)",
      "Read(~/.git-credentials)",
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Edit(~/.git-credentials)",
      "Edit(~/.ssh/**)",

      "Bash(sudo:*)",
      "Bash(rm -rf:*)",

      "Bash(qvm-*)",
      "Bash(qubes-*)",

      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(rsync:*)",
      "Bash(nc:*)",
      "Bash(ncat:*)",
      "Bash(netcat:*)",
      "Bash(wget:*)",

      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git fetch:*)",
      "Bash(git remote:*)",
      "Bash(git commit:*)",
      "Bash(git add:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(gh:*)"
    ],
    "additionalDirectories": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/hooks/guard-destructive.sh\""
          }
        ]
      }
    ]
  },
  "enableAllProjectMcpServers": false,
  "outputStyle": "default"
}

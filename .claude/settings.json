    "deny": [
      "Read(.env)",
      "Read(**/.env)",
      "Read(.env.local)",
      "Read(**/.env.local)",
      "Read(~/.claude/.credentials.json)",
      "Read(~/.git-credentials)",
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Edit(.env)",
      "Edit(**/.env)",
      "Edit(~/.claude/**)",
      "Edit(~/.git-credentials)",
      "Edit(~/.ssh/**)",
      "Write(.env)",
      "Write(**/.env)",
      "Write(~/.claude/**)",
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(qvm-*)",
      "Bash(qubes-*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(rsync:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(ncat:*)",
      "Bash(netcat:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git fetch:*)",
      "Bash(git remote:*)",
      "Bash(gh:*)"
